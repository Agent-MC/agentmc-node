      }
    },
    "/hosts/realtime/sessions/{session}/signals": {
      "get": {
        "tags": [
          "Hosts"
        ],
        "summary": "List realtime signals for one claimed session (host or agent context).",
        "description": "Returns persisted signals ordered by id so websocket clients can catch up missed events after reconnect.",
        "operationId": "listAgentRealtimeSignals",
        "parameters": [
          {
            "name": "session",
            "in": "path",
            "description": "Realtime session identifier.",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "after_id",
            "in": "query",
            "description": "Only return signals with id greater than this value.",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of signals to return.",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 200,
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Realtime signals returned."
          },
          "default": {
            "description": "Error response."
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      },
      "post": {
        "tags": [
          "Hosts"
        ],
        "summary": "Publish one realtime event to a realtime session (host or agent context).",
        "description": "Accepts host API key context by session ownership. X-Agent-Id remains optional for explicit single-agent routing.",
        "operationId": "createAgentRealtimeSignal",
        "parameters": [
          {
            "name": "session",
            "in": "path",
