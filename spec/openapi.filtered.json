{
  "openapi": "3.0.0",
  "info": {
    "title": "AgentMC API",
    "description": "API-first interface for automation agents and integrations.",
    "version": "v1"
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "Version 1 API"
    }
  ],
  "paths": {
    "/hosts/heartbeat": {
      "post": {
        "tags": [
          "Hosts"
        ],
        "summary": "Record host heartbeat and runtime telemetry.",
        "description": "Accepts heartbeat pings with required host telemetry payload and required runtime agent metadata.",
        "operationId": "agentHeartbeat",
        "parameters": [
          {
            "name": "X-Host-Fingerprint",
            "in": "header",
            "description": "Optional host fingerprint header fallback. Used only when host.fingerprint is omitted from the request body.",
            "required": false,
            "schema": {
              "type": "string",
              "maxLength": 128,
              "minLength": 64,
              "pattern": "^[A-Za-z0-9._-]+$"
            },
            "example": "a3f56f330f311a2159f8c101eaf1439a29f1d57f007375d56aa79f304bc4f112"
          }
        ],
        "responses": {
          "200": {
            "description": "Heartbeat accepted."
          },
          "401": {
            "description": "Missing or invalid API key."
          },
          "403": {
            "description": "Forbidden."
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/agents/instructions": {
      "get": {
        "tags": [
          "Agents"
        ],
        "summary": "Fetch the AgentMC instruction bundle for the authenticated agent.",
        "description": "Returns managed runtime files and bundle metadata. Send current_bundle_version to fetch files only when the bundle has changed.",
        "operationId": "getAgentInstructions",
        "parameters": [
          {
            "name": "current_bundle_version",
            "in": "query",
            "description": "Last applied instruction bundle version from local runtime state.",
            "required": false,
            "schema": {
              "type": "string",
              "maxLength": 120
            },
            "example": "bundle_2fa07fcadd6575cc"
          }
        ],
        "responses": {
          "200": {
            "description": "Instruction bundle returned."
          },
          "401": {
            "description": "Missing or invalid credentials."
          },
          "403": {
            "description": "Forbidden."
          },
          "422": {
            "description": "Validation failed."
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          },
          {
            "SessionCookieAuth": []
          }
        ]
      }
    },
